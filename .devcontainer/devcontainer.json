{
  "name": "Vinted AutoBot",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Vinted AutoBot",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },

  "postCreateCommand": "cd /workspaces/Vinted2 && pip install -r backend/requirements.txt -q && echo '✅ Deps OK'",
  "postStartCommand": "bash /workspaces/Vinted2/.devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
